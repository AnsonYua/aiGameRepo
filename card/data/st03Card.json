          "[Destroyed]Look at the top 3 cards of your deck. You may reveal 1 Zeon/Neo Zeon Unit card among them and add it to your hand. Return the rest to the bottom of your deck in random order."
        ],
        "rules": [
          {
            "effectId": "destroyed_tutor_zeon_unit_from_top_3",
            "type": "triggered",
            "action": "select_from_top_deck",
            "parameters": {
              "lookCount": 3,
              "select": {
                "count": 1,
                "optional": true,
                "toZone": "hand",
                "reveal": true,
                "filters": {
