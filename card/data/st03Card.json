    "ST03-001": {
      "id": "ST03-001",
      "name": "Sinanju",
      "cardType": "unit",
      "color": "Red",
      "level": 6,
      "cost": 5,
      "zone": [
        "Space",
        "Earth"
      ],
      "traits": [
        "Neo Zeon"
      ],
      "link": [
        "Full Frontal"
      ],
      "ap": 5,
      "hp": 4,
      "effects": {
        "description": [
          "[During Pair]This Unit gains <High-Maneuver> (This Unit can’t be blocked).",
          "During your turn, when this Unit destroys an enemy shield-area card with battle damage, choose 1 enemy Unit. Deal 2 damage to it."
        ],
        "rules": [
          {
            "effectId": "pair_grant_high_maneuver",
            "type": "continuous",
            "action": "grant_keyword",
            "sourceConditions": [
              {
                "type": "paired"
              }
            ],
            "timing": {
              "duration": "continuous"
            },
            "target": {
              "type": "unit",
              "scope": "self",
              "count": 1
            },
            "parameters": {
              "keyword": "High-Maneuver",
              "notes": "Implemented: High-Maneuver keyword grants unblockable behavior."
            }
          },
          {
            "effectId": "shield_destroy_damage_2",
            "type": "triggered",
            "action": "damage",
            "timing": {
              "actionTurn": "YOUR_TURN",
              "eventTrigger": "DEFENSE_AREA_BATTLE_DAMAGE"
            },
            "target": {
              "type": "unit",
              "scope": "opponent",
              "count": 1
            },
            "parameters": {
              "value": 2,
              "source": "battle_damage",
              "defenseAreas": [
                "shield",
                "base"
              ],
              "notes": "Implemented: triggers when this Unit deals battle damage to an opponent defense area (shield or base), matching accepted ST03-001 rules."
            }
          }
        ]
      }
    },
