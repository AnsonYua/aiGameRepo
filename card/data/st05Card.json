    "ST05-001": {
      "id": "ST05-001",
      "name": "Gundam Barbatos 4th Form",
      "cardType": "unit",
      "color": "Purple",
      "level": 6,
      "cost": 4,
      "zone": [
        "Space",
        "Earth"
      ],
      "traits": [
        "Tekkadan",
        "Gundam Frame"
      ],
      "link": [
        "Mikazuki Augus"
      ],
      "ap": 4,
      "hp": 5,
      "effects": {
        "description": [
          "[Deploy]Choose 1 of your other Units. Deal 1 damage to it. If you do, it gets AP+1 during this turn.",
          "While this Unit is damaged, it gains <Suppression>. (Damage to Shields by an attack is dealt to the first 2 cards simultaneously.)"
        ],
        "rules": [
          {
            "effectId": "deploy_damage_1_then_ap_plus_1",
            "type": "triggered",
            "action": "sequence",
            "parameters": {
              "steps": [
                {
                  "stepId": "damage_other_friendly_unit",
                  "action": "damage",
                  "target": {
                    "type": "unit",
                    "scope": "self_all_unit",
                    "count": 1,
                    "selection": {
                      "type": "player_choice"
                    }
                  },
                  "parameters": {
                    "value": 1,
                    "excludeSource": true
                  }
                },
                {
                  "action": "conditional",
                  "parameters": {
                    "if": [
                      {
                        "type": "stepResolved",
                        "stepId": "damage_other_friendly_unit"
                      }
                    ],
                    "then": [
                      {
                        "action": "modifyAP",
                        "timing": {
                          "duration": "UNTIL_END_OF_TURN"
                        },
                        "target": {
                          "type": "unit",
                          "scope": "previous_target",
                          "count": 1
                        },
                        "parameters": {
                          "value": 1
                        }
                      }
                    ]
                  }
                }
              ]
            },
            "timing": {
              "eventTrigger": "ENTERS_PLAY"
            }
          },
          {
            "effectId": "gain_suppression_while_damaged",
            "type": "continuous",
            "action": "grant_keyword",
            "target": {
              "type": "unit",
              "scope": "self",
              "count": 1
            },
            "conditions": [
              {
                "type": "sourceDamaged",
                "scope": "source",
                "value": true
              }
            ],
            "timing": {
              "duration": "continuous",
              "endOnSourceDestroyed": true
            },
            "parameters": {
              "keyword": "Suppression"
            }
          }
        ]
      }
    },
