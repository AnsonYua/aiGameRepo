      ],
      "ap": 5,
      "hp": 5,
      "effects": {
        "description": [
          "While you have no Units that are Lv.6 or higher in play, this card in your hand gets cost -1 for each enemy Unit in play.",
          "While you have no Units that are Lv.6 or higher in play, this card in your hand gets Lv.-1 for each enemy Unit in play.",
          "[When Paired]Choose 1 enemy Unit with the highest Lv. Deal 3 damage to it."
        ],
        "rules": [
          {
            "effectId": "hand_cost_minus_1_per_enemy_unit_if_no_friendly_ge_6",
            "type": "continuous",
            "action": "modifyCost",
            "target": {
              "type": "card",
              "scope": "self_hand",
              "count": 1
            },
            "conditions": [
              {
                "type": "unitsInPlayWithFilter",
                "scope": "self",
                "filters": {
                  "level": ">=6"
                },
                "value": "==0"
              }
            ],
            "parameters": {
              "value": -1,
              "scaling": {
                "type": "COUNT_UNITS_IN_PLAY",
                "scope": "opponent_all_unit"
              },
              "notes": "Implemented: cost decreases by 1 per enemy Unit in play while you control no Lv.6+ units."
            },
            "timing": {
              "duration": "continuous"
            }
          },
          {
            "effectId": "hand_level_minus_1_per_enemy_unit_if_no_friendly_ge_6",
            "type": "continuous",
            "action": "modifyLevel",
            "target": {
              "type": "card",
              "scope": "self_hand",
              "count": 1
            },
            "conditions": [
              {
                "type": "unitsInPlayWithFilter",
                "scope": "self",
                "filters": {
                  "level": ">=6"
                },
                "value": "==0"
              }
            ],
            "parameters": {
              "value": -1,
              "scaling": {
                "type": "COUNT_UNITS_IN_PLAY",
                "scope": "opponent_all_unit"
              },
              "notes": "Implemented: level decreases by 1 per enemy Unit in play while you control no Lv.6+ units."
            },
            "timing": {
              "duration": "continuous"
            }
          },
          {
            "effectId": "pair_damage_highest_level_enemy_3",
            "type": "triggered",
            "action": "damage",
            "target": {
              "type": "unit",
              "scope": "opponent_all_unit",
              "selection": {
