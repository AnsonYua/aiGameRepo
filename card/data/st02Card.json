      "effects": {
        "description": [
          "[Action]During this battle, your shield-area cards can't receive damage from enemy Units that are Lv.4 or lower.",
          "[Pilot][Quatre Raberba Winner]"
        ],
        "rules": [
          {
            "effectId": "action_prevent_shield_damage",
            "type": "play",
            "timing": {
              "duration": "UNTIL_END_OF_BATTLE",
              "activationWindows": [
                "ACTION_STEP"
              ]
            },
            "action": "sequence",
            "parameters": {
              "text": "During this battle, your shield-area cards can't receive damage from enemy Units that are Lv.4 or lower.",
              "version": 1,
              "steps": [
                {
                  "action": "prevent_shield_damage",
                  "parameters": {
                    "maxEnemyLevel": 4
                  }
                },
                {
                  "action": "prevent_battle_damage",
                  "timing": {
                    "duration": "UNTIL_END_OF_BATTLE"
                  },
                  "target": {
                    "type": "base",
                    "scope": "self"
                  },
                  "parameters": {
                    "from": "enemy_units",
                    "enemyLevel": "<=4"
                  }
                }
              ],
              "notes": "Shield-area wording includes both shields and base: step1 applies shield prevention, step2 applies base battle-damage prevention."
            }
          },
          {
            "effectId": "pilot_designation",
            "action": "designate_pilot",
            "parameters": {
              "pilotName": "Quatre Raberba Winner",
              "AP": 1,
              "HP": 1
            },
            "type": "special",
            "timing": {
