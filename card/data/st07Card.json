    "ST07-001": {
      "id": "ST07-001",
      "name": "Gundam Exia",
      "cardType": "unit",
      "color": "Purple",
      "level": 5,
      "cost": 4,
      "zone": [
        "Space",
        "Earth"
      ],
      "traits": [
        "CB",
        "GN Drive"
      ],
      "link": [
        "Setsuna F. Seiei"
      ],
      "ap": 4,
      "hp": 4,
      "effects": {
        "description": [
          "At the end of your turn, if there are 7 or more (CB) cards in your trash, choose 1 of your Resources. Set it as active.",
          "[When Paired]Place the top 2 cards of your deck into your trash. If you placed a (CB) card with this effect, draw 1."
        ],
        "rules": [
          {
            "effectId": "end_of_turn_set_active_resource_if_cb_trash_ge_7",
            "type": "triggered",
            "timing": {
              "actionTurn": "YOUR_TURN",
              "eventTrigger": "END_OF_TURN"
            },
            "conditions": [
              {
                "type": "cardsInTrash",
                "scope": "self",
                "traitsAny": [
                  "CB"
                ],
                "value": ">=7"
              }
            ],
            "action": "setActive",
            "target": {
              "type": "energy",
              "scope": "self_resource",
              "count": 1,
              "filters": {
                "status": "rested",
                "isExtraEnergy": false
              }
            },
            "parameters": {}
          },
          {
            "effectId": "pair_mill_2_then_draw_if_cb_milled",
            "type": "triggered",
            "action": "sequence",
            "parameters": {
              "steps": [
                {
                  "action": "moveTopDeckToTrash",
                  "parameters": {
                    "count": 2,
                    "reveal": false
                  }
                },
                {
                  "action": "draw_if_moved_cards_match_traits",
                  "parameters": {
                    "value": 1,
                    "traitsAny": [
                      "CB"
                    ],
                    "notes": "Conditional follow-up based on cards moved by the previous step."
                  }
                }
              ]
            },
            "timing": {
              "eventTrigger": "PAIRING_COMPLETE"
            }
          }
        ]
      }
    },
