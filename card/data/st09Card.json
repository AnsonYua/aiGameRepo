    "ST09-001": {
      "id": "ST09-001",
      "name": "Impulse Gundam",
      "cardType": "unit",
      "color": "Purple",
      "level": 3,
      "cost": 2,
      "zone": [
        "Space",
        "Earth"
      ],
      "traits": [
        "ZAFT",
        "Minerva Squad"
      ],
      "link": [
        "Shinn Asuka"
      ],
      "ap": 3,
      "hp": 3,
      "effects": {
        "description": [
          "[Activate/Main](2): Return this Unit to the bottom of its owner's deck. Choose 1 Unit card with \"Impulse Gundam\" in its card name that is Lv.4 or higher from your trash. Deploy it."
        ],
        "rules": [
          {
            "effectId": "activate_return_self_then_deploy_impulse_from_trash",
            "type": "activated",
            "timing": {
              "activationWindows": [
                "MAIN_PHASE"
              ]
            },
            "cost": {
              "resource": 2
            },
            "action": "sequence",
            "parameters": {
              "text": "Return this Unit to the bottom of its owner's deck. Choose 1 Unit card with \"Impulse Gundam\" in its card name that is Lv.4 or higher from your trash. Deploy it.",
              "version": 1,
              "steps": [
                {
                  "stepId": "return_self_to_deck_bottom",
                  "action": "returnToDeckBottom",
                  "target": {
                    "type": "card",
                    "scope": "self"
                  }
                },
                {
                  "action": "deploy",
                  "target": {
                    "type": "card",
                    "scope": "self_trash",
                    "count": 1,
                    "selection": {
                      "type": "player_choice"
                    },
                    "filters": {
                      "cardType": "unit",
                      "level": ">=4",
                      "nameIncludes": "Impulse Gundam"
                    }
                  },
                  "parameters": {
                    "payCost": false,
                    "notes": "Official FAQ confirms the deployed Unit is not paid for."
                  }
                }
              ]
            }
          }
        ]
      }
    },
